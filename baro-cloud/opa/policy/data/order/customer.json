                                                    "methods":  [
                                                                    "GET"
                                                                ],
                                                    "roles":  [
                                                                  "CUSTOMER",
                                                                  "ADMIN"
                                                              ]
                                                },
                        "order:deposits-actions":  {
                                                       "name":  "order:deposits-actions",
