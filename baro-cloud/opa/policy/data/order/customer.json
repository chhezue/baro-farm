                                                    "methods":  [
                                                                    "POST"
                                                                ],
                                                    "roles":  [
                                                                  "CUSTOMER",
                                                                  "ADMIN"
                                                              ],
                                                    "deny_flags":  [
                                                                       "ORDER_BLOCKED"
                                                                   ]
                                                }
                    },
    "index":  {
                  "method":  {
                                 "GET":  [
                                             "order:deposits-list",
                                             "order:orders-list",
                                             "order:order-detail"
                                         ],
                                 "POST":  [
                                              "order:deposits-actions",
                                              "order:orders-create",
                                              "order:payments-toss"
