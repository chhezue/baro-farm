                                                       "methods":  [
                                                                       "POST"
                                                                   ],
                                                       "roles":  [
                                                                     "CUSTOMER",
                                                                     "ADMIN"
                                                                 ],
                                                       "deny_flags":  [
                                                                          "ORDER_BLOCKED"
                                                                      ]
                                                   },
                        "order:orders-list":  {
                                                  "name":  "order:orders-list",
                                                  "path":  "^/api/v1/orders$",
                                                  "methods":  [
                                                                  "GET"
                                                              ],
                                                  "roles":  [
                                                                "CUSTOMER",
                                                                "ADMIN"
                                                            ]
                                              },
                        "order:orders-create":  {
                                                    "name":  "order:orders-create",
                                                    "path":  "^/api/v1/orders$",
                                                    "methods":  [
                                                                    "POST"
                                                                ],
                                                    "roles":  [
                                                                  "CUSTOMER",
                                                                  "ADMIN"
                                                              ],
                                                    "deny_flags":  [
                                                                       "ORDER_BLOCKED"
                                                                   ]
                                                },
                        "order:order-detail":  {
                                                   "name":  "order:order-detail",
                                                   "path":  "^/api/v1/orders/[^/]+$",
                                                   "methods":  [
                                                                   "GET"
                                                               ],
                                                   "roles":  [
                                                                 "CUSTOMER",
                                                                 "ADMIN"
                                                             ]
                                               },
                        "order:order-cancel":  {
                                                   "name":  "order:order-cancel",
                                                   "path":  "^/api/v1/orders/[^/]+/cancel$",
                                                   "methods":  [
