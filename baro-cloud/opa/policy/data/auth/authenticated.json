{
    "rules_by_id":  {
                        "auth:auth-me":  {
                                             "name":  "auth:auth-me",
                                             "path":  "^(/auth-service)?/api/v1/auth/me$",
                                             "methods":  [
                                                             "GET"
                                                         ],
                                             "roles":  [
                                                           "CUSTOMER",
                                                           "SELLER",
                                                           "ADMIN"
                                                       ]
                                         },
                        "auth:auth-withdraw":  {
                                                   "name":  "auth:auth-withdraw",
