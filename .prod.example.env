# =========================
# 운영(PROD) 환경변수 명세 파일 (예시)
# 실제 값은 GitHub Actions Secret & Kubernetes Secret & ConfigMap에서 주입
# =========================
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080

# -------------------------------------------------
# baro-gateway
# -------------------------------------------------
SPRING_DATA_REDIS_HOST=         # Redis 호스트 (Gateway/ConfigMap)
SPRING_DATA_REDIS_PORT=         # Redis 포트 (Gateway/ConfigMap)
SPRING_DATA_REDIS_PASSWORD=     # Redis 인증 비밀번호 (K8S secret)
REDIS_HOST=                     # Redis fallback 호스트 (k8s/apps/common/infra-configmap.yml)
REDIS_PORT=6379                 # Redis fallback 포트 (k8s/apps/common/infra-configmap.yml)
GATEWAY_ALLOWED_ORIGIN_0=http://localhost:3000                  # 허용할 프론트 origin 1
GATEWAY_ALLOWED_ORIGIN_1=http://3.34.14.73:3000                 # 허용할 프론트 origin 2
JWT_SECRET=                     # Github Actions Secret

# -------------------------------------------------
# baro-user
# -------------------------------------------------
AWS_ACCESS_KEY_ID=	        # (기존) ECR/kubectl용
AWS_SECRET_ACCESS_KEY=	    # (기존)
KUBE_CONFIG=	            # (기존) kubeconfig base64
MYSQL_APP_PASSWORD=	        # (기존) mysql-credentials
REDIS_PASSWORD=	            # (기존) redis-credentials
BARO_USER_JWT_SECRET=	    # JWT 서명 키 (JWT_SECRET와 동일, Github Actions Secret)
BARO_USER_MAIL_USERNAME=	# 메일 발송 계정 (Github Actions Secret)
BARO_USER_MAIL_PASSWORD=	# 메일 발송 비밀번호 (Github Actions Secret)
BARO_USER_KAKAO_CLIENT_ID=	# 카카오 OAuth (Github Actions Secret)

# -------------------------------------------------
# baro-shopping
# -------------------------------------------------
AWS_ACCESS_KEY_ID=	        # (기존) ECR/kubectl용
AWS_SECRET_ACCESS_KEY=	    # (기존)
KUBE_CONFIG=	            # (기존) kubeconfig base64
MYSQL_APP_PASSWORD=	        # (기존) mysql-credentials
BARO_SHOPPING_S3_BUCKET=	# S3 버킷 이름 (이미지 업로드용, Github Actions Secret)

# -------------------------------------------------
# baro-order
# -------------------------------------------------
AWS_ACCESS_KEY_ID=	        # (기존) ECR/kubectl용
AWS_SECRET_ACCESS_KEY=	    # (기존)
KUBE_CONFIG=	            # (기존) kubeconfig base64
MYSQL_APP_PASSWORD=	        # (기존) mysql-credentials (baro_order DB 접근)
BARO_ORDER_S3_BUCKET=	    # S3 버킷 이름 (리뷰 이미지 업로드용, Github Actions Secret)

# -------------------------------------------------
# baro-payment
# -------------------------------------------------
AWS_ACCESS_KEY_ID=	            # (기존) ECR/kubectl용
AWS_SECRET_ACCESS_KEY=	        # (기존)
KUBE_CONFIG=	                # (기존) kubeconfig base64
MYSQL_APP_PASSWORD=	            # (기존) mysql-credentials (baro_payment DB 접근)
BARO_PAYMENT_TOSS_SECRET_KEY=	# 토스페이먼츠 시크릿 키 (Github Actions Secret)

# -------------------------------------------------
# baro-notification
# -------------------------------------------------
AWS_ACCESS_KEY_ID=	            # (기존) ECR/kubectl용
AWS_SECRET_ACCESS_KEY=	        # (기존)
KUBE_CONFIG=	                # (기존) kubeconfig base64
MYSQL_APP_PASSWORD=	            # (기존) mysql-credentials (baro_notification DB 접근)
BARO_NOTI_MAIL_USERNAME=	    # 메일 발송 계정 (Github Actions Secret)
BARO_NOTI_MAIL_PASSWORD=	    # 메일 발송 비밀번호 (Github Actions Secret)

# -------------------------------------------------
# baro-ai
# -------------------------------------------------
AWS_ACCESS_KEY_ID=	            # (기존) ECR/kubectl용
AWS_SECRET_ACCESS_KEY=	        # (기존)
KUBE_CONFIG=	                # (기존) kubeconfig base64
BARO_AI_OPENAI_KEY=	            # OpenAI API Key (Github Actions Secret)
